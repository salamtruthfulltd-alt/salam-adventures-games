<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Counting Adventure Pro</title>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #1e293b;
            --machine: #334155;
            --screen: #7dd3fc;
            --accent: #fbbf24;
            --success: #4ade80;
            --error: #f87171;
        }

        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: var(--bg);
            font-family: 'Nunito', sans-serif;
            overflow: hidden;
        }

        /* Arcade Casing */
        .arcade-casing {
            width: 450px;
            background: var(--machine);
            padding: 30px;
            border-radius: 40px 40px 15px 15px;
            box-shadow: 0 20px 0 #1e293b, inset 0 5px 10px rgba(255,255,255,0.2);
            position: relative;
            border: 8px solid #475569;
        }

        .header-panel {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
            color: white;
            text-transform: uppercase;
            font-size: 14px;
            letter-spacing: 2px;
        }

        /* Game Screen */
        .game-screen {
            background: var(--screen);
            height: 350px;
            border-radius: 20px;
            border: 10px solid #0f172a;
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            box-shadow: inset 0 0 50px rgba(0,0,0,0.1);
        }

        .target-number {
            font-family: 'Fredoka One', cursive;
            font-size: 80px;
            color: #0369a1;
            margin: 0;
            text-shadow: 4px 4px 0px rgba(255,255,255,0.5);
            animation: bounce 2s infinite;
        }

        .instruction {
            color: #0c4a6e;
            font-weight: 800;
            margin-bottom: 20px;
        }

        /* Item Grid */
        .item-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 12px;
            padding: 10px;
        }

        .item {
            font-size: 40px;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            filter: grayscale(1) opacity(0.3);
            user-select: none;
        }

        .item.active {
            filter: grayscale(0) opacity(1);
            transform: scale(1.2);
        }

        .item:active {
            transform: scale(0.9);
        }

        /* Controls */
        .controls {
            margin-top: 30px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .btn {
            padding: 15px;
            border: none;
            border-radius: 15px;
            font-family: 'Fredoka One', cursive;
            font-size: 18px;
            cursor: pointer;
            text-transform: uppercase;
            transition: all 0.1s;
            box-shadow: 0 6px 0 rgba(0,0,0,0.3);
        }

        .btn:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0 rgba(0,0,0,0.3);
        }

        .btn-submit { background: var(--success); color: #064e3b; }
        .btn-reset { background: var(--error); color: #7f1d1d; }

        /* Animations */
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .confetti {
            position: absolute;
            width: 10px;
            height: 10px;
            background: red;
            animation: fall 3s linear forwards;
        }

        @keyframes fall {
            to { transform: translateY(400px) rotate(360deg); opacity: 0; }
        }

        .level-up-flash {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: white;
            opacity: 0;
            pointer-events: none;
            z-index: 10;
        }
    </style>
</head>
<body>

<div class="arcade-casing">
    <div class="header-panel">
        <div>Level: <span id="level-val">1</span></div>
        <div>Score: <span id="score-val">0</span></div>
    </div>

    <div class="game-screen" id="screen">
        <div class="level-up-flash" id="flash"></div>
        <p class="instruction">Can you find...</p>
        <h1 class="target-number" id="target">?</h1>
        
        <div class="item-grid" id="grid"></div>
    </div>

    <div class="controls">
        <button class="btn btn-reset" onclick="resetCount()">Clear</button>
        <button class="btn btn-submit" onclick="checkAnswer()">Submit</button>
    </div>
</div>

<script>
    // Sound Engine (Web Audio API)
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    
    function playSound(freq, type, duration) {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = type;
        osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
        gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + duration);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + duration);
    }

    const sounds = {
        click: () => playSound(400 + (state.currentCount * 50), 'sine', 0.1),
        win: () => {
            playSound(523.25, 'square', 0.1);
            setTimeout(() => playSound(659.25, 'square', 0.1), 100);
            setTimeout(() => playSound(783.99, 'square', 0.3), 200);
        },
        error: () => playSound(150, 'sawtooth', 0.3),
        reset: () => playSound(300, 'sine', 0.1)
    };

    // Game Logic
    const state = {
        level: 1,
        score: 0,
        target: 0,
        currentCount: 0,
        emoji: ['🍎', '⭐️', '🐸', '🚀', '🐱', '🍦', '🐼', '🦖']
    };

    function initLevel() {
        state.target = Math.floor(Math.random() * 10) + 1;
        state.currentCount = 0;
        const currentEmoji = state.emoji[Math.floor(Math.random() * state.emoji.length)];
        
        document.getElementById('target').textContent = state.target;
        document.getElementById('level-val').textContent = state.level;
        document.getElementById('score-val').textContent = state.score;
        
        const grid = document.getElementById('grid');
        grid.innerHTML = '';
        
        for (let i = 1; i <= 10; i++) {
            const div = document.createElement('div');
            div.className = 'item';
            div.textContent = currentEmoji;
            div.dataset.index = i;
            div.onclick = () => selectTo(i);
            grid.appendChild(div);
        }
    }

    function selectTo(num) {
        state.currentCount = num;
        sounds.click();
        const items = document.querySelectorAll('.item');
        items.forEach((item, idx) => {
            if (idx < num) item.classList.add('active');
            else item.classList.remove('active');
        });
    }

    function resetCount() {
        state.currentCount = 0;
        sounds.reset();
        document.querySelectorAll('.item').forEach(i => i.classList.remove('active'));
    }

    function checkAnswer() {
        if (state.currentCount === state.target) {
            handleWin();
        } else {
            handleLoss();
        }
    }

    function handleWin() {
        sounds.win();
        state.score += 10;
        state.level++;
        
        // Visual feedback
        const flash = document.getElementById('flash');
        flash.style.opacity = '0.8';
        setTimeout(() => flash.style.opacity = '0', 200);
        
        createConfetti();
        
        setTimeout(initLevel, 1000);
    }

    function handleLoss() {
        sounds.error();
        const screen = document.getElementById('screen');
        screen.style.borderColor = 'var(--error)';
        setTimeout(() => screen.style.borderColor = '#0f172a', 500);
        resetCount();
    }

    function createConfetti() {
        for (let i = 0; i < 30; i++) {
            const c = document.createElement('div');
            c.className = 'confetti';
            c.style.left = Math.random() * 100 + '%';
            c.style.background = `hsl(${Math.random() * 360}, 100%, 50%)`;
            c.style.transform = `rotate(${Math.random() * 360}deg)`;
            document.getElementById('screen').appendChild(c);
            setTimeout(() => c.remove(), 3000);
        }
    }

    // Start
    initLevel();
</script>

</body>
</html>
